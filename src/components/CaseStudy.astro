---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  result: string;
  tags: string[];
  variant: "research" | "geo" | "health" | "systems";
  href?: string;
  linkLabel?: string;
  featured?: boolean;
  privateWork?: boolean;
}

const {
  eyebrow,
  title,
  summary,
  result,
  tags,
  variant,
  href,
  linkLabel = "View project",
  featured = false,
  privateWork = false
} = Astro.props;
---

<article class:list={["case-study", { featured }]}>
  <div class:list={["case-visual", `visual-${variant}`]} aria-hidden="true">
    {variant === "research" && (
      <svg viewBox="0 0 620 360">
        <defs>
          <pattern id="research-grid" width="32" height="32" patternUnits="userSpaceOnUse">
            <path d="M32 0H0V32" fill="none" stroke="currentColor" stroke-opacity=".13" />
          </pattern>
        </defs>
        <rect width="620" height="360" fill="url(#research-grid)" />
        <path class="line-heavy" d="M52 274C124 251 132 154 214 182s100 75 170 11 97-67 184-109" />
        <path class="line-light" d="M52 294c74-12 134-52 201-42s93 33 159-6 96-67 156-72" />
        <g class="nodes">
          <circle cx="52" cy="274" r="7" /><circle cx="214" cy="182" r="7" />
          <circle cx="384" cy="193" r="7" /><circle cx="568" cy="84" r="7" />
        </g>
        <g class="axis-labels">
          <text x="52" y="45">QUESTION</text><text x="218" y="45">EVIDENCE</text>
          <text x="382" y="45">ANALYSIS</text><text x="518" y="45">OUTPUT</text>
        </g>
      </svg>
    )}
    {variant === "geo" && (
      <svg viewBox="0 0 620 360">
        <path class="terrain terrain-a" d="M-20 275c78-77 157-10 222-84 81-91 166 36 231-42 69-83 136-41 207-93v324H-20z" />
        <path class="terrain terrain-b" d="M-20 318c100-45 155-3 232-62 90-69 159 42 248-32 58-48 109-29 180-58v214H-20z" />
        <path class="route" d="M46 282c53-36 80-88 139-76 80 17 102-87 178-64 58 17 81 105 153 45l62-51" />
        <g class="samples">
          <circle cx="46" cy="282" r="7" /><circle cx="185" cy="206" r="7" />
          <circle cx="363" cy="142" r="7" /><circle cx="516" cy="187" r="7" />
        </g>
        <text x="44" y="54">SPATIAL ASSESSMENT / 2-STAGE SAMPLE</text>
      </svg>
    )}
    {variant === "health" && (
      <svg viewBox="0 0 620 360">
        <g class="health-bars">
          <rect x="54" y="196" width="48" height="106" /><rect x="120" y="128" width="48" height="174" />
          <rect x="186" y="166" width="48" height="136" /><rect x="252" y="92" width="48" height="210" />
          <rect x="318" y="145" width="48" height="157" /><rect x="384" y="116" width="48" height="186" />
        </g>
        <path class="health-line" d="M54 179c60-54 95 13 159-29s107 32 172-22 113-15 181-75" />
        <circle cx="566" cy="53" r="9" class="health-point" />
        <text x="54" y="54">27 INDICATORS / TERRITORIAL VIEW</text>
        <text x="484" y="302">300+ USERS</text>
      </svg>
    )}
    {variant === "systems" && (
      <svg viewBox="0 0 620 360">
        <g class="system-boxes">
          <rect x="55" y="74" width="138" height="74" rx="4" />
          <rect x="241" y="74" width="138" height="74" rx="4" />
          <rect x="427" y="74" width="138" height="74" rx="4" />
          <rect x="148" y="214" width="138" height="74" rx="4" />
          <rect x="334" y="214" width="138" height="74" rx="4" />
        </g>
        <g class="system-links">
          <path d="M193 111h48M379 111h48M124 148l72 66M496 148l-72 66M286 251h48" />
        </g>
        <g class="system-labels">
          <text x="86" y="118">REQUEST</text><text x="279" y="118">DATA</text>
          <text x="456" y="118">REVIEW</text><text x="175" y="258">CERTIFY</text>
          <text x="364" y="258">REPORT</text>
        </g>
      </svg>
    )}
    <span class="visual-index">{variant === "research" ? "R/01" : variant === "geo" ? "G/02" : variant === "health" ? "H/03" : "S/04"}</span>
  </div>

  <div class="case-copy">
    <div class="case-meta">
      <span>{eyebrow}</span>
      {privateWork && <span class="private-label">Private code · Production</span>}
    </div>
    <h3>{title}</h3>
    <p>{summary}</p>
    <p class="case-result"><span>Outcome</span>{result}</p>
    <ul class="tag-list" aria-label="Technologies and methods">
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
    {href && (
      <a class="text-link" href={href} target="_blank" rel="noreferrer">
        {linkLabel}<span aria-hidden="true">↗</span>
      </a>
    )}
  </div>
</article>
