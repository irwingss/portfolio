---
import BaseLayout from "../layouts/BaseLayout.astro";
import IdentityRail from "../components/IdentityRail.astro";
import CaseStudy from "../components/CaseStudy.astro";

const title = "Irwing Saldaña — Data Scientist & ML / AI Engineer";
const description = "Data scientist and ML/AI engineer building production systems for science, health, and environmental decision-making.";
---

<BaseLayout {title} {description}>
  <div class="site-shell" id="top">
    <IdentityRail />

    <main class="main-content" id="content">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy reveal">
          <p class="eyebrow">Data science · Machine learning · Applied AI</p>
          <h1 id="hero-title">A scientist who<br /><em>ships systems.</em></h1>
          <p class="hero-intro">
            I turn complex scientific and operational problems into reproducible analytics,
            AI-assisted products, and software that people actually use.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="#work">Explore selected work</a>
            <a class="button button-quiet" href="mailto:irwing.s.saldana@gmail.com">Start a conversation <span aria-hidden="true">↗</span></a>
          </div>
        </div>

        <div class="hero-note reveal">
          <span class="note-number">01—04</span>
          <p>
            Biology gave me the questions. Statistics gave me rigor. Engineering gave me a way
            to put both into production.
          </p>
        </div>
      </section>

      <section class="evidence-strip reveal" aria-label="Selected outcomes">
        <div>
          <strong>2 weeks → &lt;3 days</strong>
          <span>Environmental report drafting</span>
        </div>
        <div>
          <strong>4 months → 3 weeks</strong>
          <span>Academic certificate turnaround</span>
        </div>
        <div>
          <strong>300+ active users</strong>
          <span>Public-health AI assistant</span>
        </div>
      </section>

      <section class="section-block" id="work" aria-labelledby="work-title">
        <header class="section-header reveal">
          <p class="section-index">01 / Selected work</p>
          <div>
            <h2 id="work-title">Systems built around<br />real constraints.</h2>
            <p>
              Public product work and closed-source systems presented through the problems,
              decisions, and measurable outcomes they produced.
            </p>
          </div>
        </header>

        <div class="work-list">
          <div class="reveal">
            <CaseStudy
              featured
              eyebrow="Founder & sole developer · Live beta"
              title="Ressearch AI"
              summary="An AI-powered scientific research platform supporting the research lifecycle, with built-in statistical and spatial analysis modules. I designed and shipped the frontend, backend, data layer, and AI integration."
              result="A live full-stack product launched from concept to beta in three months, now expanding toward university partnerships."
              tags={["AI product", "Full-stack", "Statistical computing", "Spatial analysis"]}
              variant="research"
              href="https://ressearchai.app/"
              linkLabel="Visit Ressearch AI"
            />
          </div>

          <div class="reveal">
            <CaseStudy
              privateWork
              eyebrow="Environmental regulation · Applied AI"
              title="AI-assisted supervision workflow"
              summary="A production desktop application combining retrieval-augmented generation with GIS automation to help environmental specialists draft evidence-grounded supervision reports."
              result="Reduced a recurring drafting workflow from roughly two weeks to under three days."
              tags={["RAG", "Gemini", "Next.js", "Electron", "ArcPy"]}
              variant="geo"
            />
          </div>

          <div class="reveal">
            <CaseStudy
              privateWork
              eyebrow="Public health · Data systems"
              title="Territorial health intelligence"
              summary="An end-to-end information system spanning REDCap collection, validation, a 27-indicator KPI framework, Power BI reporting, spatial layers, and an AI assistant for health professionals."
              result="The assistant reached 300+ active users; the wider system supported population monitoring across Peru."
              tags={["Python", "Power BI", "REDCap", "GIS", "LLM application"]}
              variant="health"
            />
          </div>

          <div class="reveal">
            <CaseStudy
              privateWork
              eyebrow="Health education · Operations"
              title="Academic management platform"
              summary="A web application deployed on a pediatric institute's production infrastructure to unify requests, enrollment, grading, attendance, and certificate generation."
              result="Reduced certificate turnaround from approximately four months to three weeks."
              tags={["Next.js", "Express", "SQL Server", "Workflow design"]}
              variant="systems"
            />
          </div>
        </div>
      </section>

      <section class="section-block" id="capabilities" aria-labelledby="capabilities-title">
        <header class="section-header reveal">
          <p class="section-index">02 / Capabilities</p>
          <div>
            <h2 id="capabilities-title">From raw evidence<br />to running product.</h2>
            <p>My strongest work sits where domain knowledge, quantitative rigor, and delivery overlap.</p>
          </div>
        </header>

        <div class="capability-grid">
          <article class="capability reveal">
            <span>01</span>
            <h3>Data science</h3>
            <p>EDA, regression, sampling design, KPI systems, validation logic, reproducible analysis, and decision-focused reporting.</p>
            <ul>
              <li>Python · pandas · GeoPandas</li>
              <li>R · SQL · Stata</li>
              <li>Biostatistics · survey data</li>
            </ul>
          </article>
          <article class="capability reveal">
            <span>02</span>
            <h3>ML & AI engineering</h3>
            <p>LLM applications, retrieval pipelines, evaluation-aware prompting, MLOps foundations, and full-stack product delivery.</p>
            <ul>
              <li>RAG · LLM applications</li>
              <li>MLflow · SageMaker · Azure ML</li>
              <li>Next.js · React · Express</li>
            </ul>
          </article>
          <article class="capability reveal">
            <span>03</span>
            <h3>Scientific & geospatial</h3>
            <p>Spatial analysis, environmental monitoring, biodiversity research, remote-sensing foundations, and scientific communication.</p>
            <ul>
              <li>ArcGIS Pro · QGIS · ArcPy</li>
              <li>Google Earth Engine</li>
              <li>Ecology · health · environment</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="section-block" id="experience" aria-labelledby="experience-title">
        <header class="section-header reveal">
          <p class="section-index">03 / Experience</p>
          <div>
            <h2 id="experience-title">A path through science,<br />data, and software.</h2>
          </div>
        </header>

        <div class="timeline">
          <article class="timeline-row reveal">
            <time>2026—Now</time>
            <div><h3>Founder & Developer</h3><p>Ressearch AI</p></div>
            <p>Building an AI research platform across product, engineering, data, and university-facing strategy.</p>
          </article>
          <article class="timeline-row reveal">
            <time>2025</time>
            <div><h3>Academic Systems & Data Lead</h3><p>National Institute of Children's Health</p></div>
            <p>Designed and deployed a production academic operations platform.</p>
          </article>
          <article class="timeline-row reveal">
            <time>2025</time>
            <div><h3>Environmental Data & Automation Lead</h3><p>OEFA · Ministry of Environment</p></div>
            <p>Shipped AI-assisted reporting, statistical sampling, GIS automation, and executive analytics.</p>
          </article>
          <article class="timeline-row reveal">
            <time>2023—25</time>
            <div><h3>Health Data Processing Lead</h3><p>MINSA · Directorate of Indigenous Peoples</p></div>
            <p>Led indicator design, field-data systems, spatial reporting, and public-health AI tooling.</p>
          </article>
          <article class="timeline-row reveal">
            <time>2016—24</time>
            <div><h3>Research, Analytics & Teaching</h3><p>INEI · ECU · CIBTYC · universities</p></div>
            <p>Built the scientific foundation: applied statistics, biodiversity research, GIS, survey QA, and four years teaching R.</p>
          </article>
        </div>
      </section>

      <section class="section-block" id="research" aria-labelledby="research-title">
        <header class="section-header reveal">
          <p class="section-index">04 / Research</p>
          <div>
            <h2 id="research-title">Scientific depth is<br />part of the stack.</h2>
            <p>Peer-reviewed research, technical books, field science, and reproducible methods inform how I build.</p>
          </div>
        </header>

        <div class="research-layout">
          <div class="publication-list">
            <article class="publication reveal">
              <span>Peer-reviewed · First author</span>
              <h3>Bird diversity and noteworthy records from the Porculla Pass and Huancabamba–Chamaya sub-basin</h3>
            </article>
            <article class="publication reveal">
              <span>Peer-reviewed · Co-author</span>
              <h3>Digital inclusion in Indigenous peoples: advances and challenges, 2019–2024</h3>
            </article>
            <article class="publication reveal">
              <span>Book</span>
              <h3>Introducción a R para Ciencias</h3>
            </article>
            <article class="publication reveal">
              <span>Technical book · Co-author</span>
              <h3>Fauna Silvestre del Área de Conservación Regional Bosques Secos del Marañón</h3>
            </article>
          </div>

          <aside class="education-note reveal">
            <p class="note-label">Education</p>
            <div>
              <strong>M.Sc. Artificial Intelligence</strong>
              <span>Universidad Continental · 2026—present</span>
            </div>
            <div>
              <strong>M.Ed. Higher Education Teaching & Research</strong>
              <span>Coursework completed</span>
            </div>
            <div>
              <strong>B.Sc. Biological Sciences</strong>
              <span>Universidad Nacional de Trujillo · Top 5%</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="contact-section" id="contact" aria-labelledby="contact-title">
        <p class="section-index reveal">05 / Contact</p>
        <div class="contact-grid">
          <div class="reveal">
            <h2 id="contact-title">Have a hard problem<br />worth shipping?</h2>
            <p>
              I am open to Data Scientist, ML Engineer, and AI Engineer roles—remote worldwide
              or relocation with visa sponsorship.
            </p>
          </div>
          <div class="contact-actions reveal">
            <a href="mailto:irwing.s.saldana@gmail.com">irwing.s.saldana@gmail.com <span aria-hidden="true">↗</span></a>
            <a href="https://www.linkedin.com/in/isaldanau/" target="_blank" rel="noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
            <a href="https://github.com/irwingss" target="_blank" rel="noreferrer">GitHub <span aria-hidden="true">↗</span></a>
            <button type="button" id="print-resume">Print / save as PDF <span aria-hidden="true">↓</span></button>
          </div>
        </div>
        <footer>
          <p>© {new Date().getFullYear()} Irwing Saldaña</p>
          <p>Built with Astro · Lima, Peru</p>
        </footer>
      </section>
    </main>
  </div>

  <script>
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealItems = document.querySelectorAll<HTMLElement>(".reveal");

    if (prefersReducedMotion || !("IntersectionObserver" in window)) {
      revealItems.forEach((item) => item.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: "0px 0px -8%", threshold: 0.08 });

      revealItems.forEach((item) => observer.observe(item));
    }

    document.querySelector<HTMLButtonElement>("#print-resume")?.addEventListener("click", () => window.print());

    const navLinks = [...document.querySelectorAll<HTMLAnchorElement>(".rail-nav a")];
    const sections = navLinks
      .map((link) => document.querySelector<HTMLElement>(link.hash))
      .filter((section): section is HTMLElement => Boolean(section));

    if (sections.length && "IntersectionObserver" in window) {
      const navObserver = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visible) return;
        navLinks.forEach((link) => link.removeAttribute("aria-current"));
        document.querySelector<HTMLAnchorElement>(`.rail-nav a[href="#${visible.target.id}"]`)
          ?.setAttribute("aria-current", "true");
      }, { rootMargin: "-20% 0px -70%", threshold: 0 });

      sections.forEach((section) => navObserver.observe(section));
    }
  </script>
</BaseLayout>
